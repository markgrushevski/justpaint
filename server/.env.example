# Copy to .env for local dev (never commit .env). The server reads these from the environment.

# HTTP
ADDR=:8080
LOG_LEVEL=info

# Postgres (used once the DB layer lands; see docs/ROADMAP.md Phase 1)
DATABASE_URL=postgres://justpaint:justpaint@localhost:5432/justpaint?sslmode=disable

# Auth — MANDATORY. The server fails fast if unset; outside dev it also rejects
# secrets shorter than 32 bytes. Generate one:  openssl rand -base64 48
JWT_SECRET=replace-with-output-of-openssl-rand-base64-48

# Judge raster renderer. "stub" (default) is the zero-dep in-process stand-in;
# "node" renders the authoritative raster via the Node worker (needs `node` on
# PATH + `npm run build -w @justpaint/render`, and RENDER_CLI set). The server
# fails fast if RENDER_MODE=node without RENDER_CLI.
RENDER_MODE=stub
# RENDER_CLI=/abs/path/to/packages/render/dist/render.mjs
# RENDER_NODE_BIN=node

# AI assist (docs/ASSIST.md). "fake" (default) returns a deterministic canned op
# batch — no API key, the whole client flow works with zero API dependency.
# "anthropic" calls the real LLM (scaffolded in Phase A) and REQUIRES
# ANTHROPIC_API_KEY; the server fails fast if ASSIST_MODE=anthropic without it.
# The key is server-side only and never reaches the client.
ASSIST_MODE=fake
# ANTHROPIC_API_KEY=sk-ant-...
# ASSIST_MODEL=claude-opus-4-8
