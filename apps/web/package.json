{
    "name": "@justpaint/web",
    "type": "module",
    "private": true,
    "scripts": {
        "types": "vue-tsc",
        "types:watch": "vue-tsc --watch",
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint:prettier": "npx prettier --write **/*.{vue,js,ts,css,json,md,html}",
        "lint:stylelint": "npx stylelint --fix **/*.{vue,css}",
        "lint:eslint": "npx eslint --fix **/*.{vue,js,ts}",
