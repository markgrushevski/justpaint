        "test:a11y": "playwright test"
    },
    "dependencies": {
        "@justpaint/document": "*",
        "@justpaint/editor": "*",
        "@oriui/css": "1.0.0-alpha.8",
        "@oriui/headless": "1.0.0-alpha.8",
        "@oriui/vue": "1.0.0-alpha.8",
        "@tanstack/vue-query": "^5.101.2",
        "colord": "^2.9.3",
        "pinia": "^3.0.4",
        "vue": "^3.5.11",
        "vue-router": "^5.1.0"
    },
    "devDependencies": {
        "@axe-core/playwright": "^4.12.1",
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.61.1",
        "@vitejs/plugin-vue": "^6.0.7",
        "autoprefixer": "^10.5.2",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.9.2",
        "globals": "^17.7.0",
        "postcss-html": "^1.8.1",
        "prettier": "^3.9.4",
        "stylelint": "^17.14.0",
        "stylelint-config-standard-vue": "^1.0.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.62.1",
        "vite": "^8.1.3",
        "vue-tsc": "^3.3.6"
    }
