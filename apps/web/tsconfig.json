{
    "include": ["src"],
    "compilerOptions": {
        "noEmit": true,
        "strict": true,
        "skipLibCheck": true,
        "isolatedModules": true,
        "esModuleInterop": true,
        "verbatimModuleSyntax": true,
        "allowImportingTsExtensions": true,
        "allowSyntheticDefaultImports": true,
        // TS 6 defaults noUncheckedSideEffectImports on; the app legitimately does
        // CSS-only side-effect imports (`@oriui/css` resolves to styles.css, no .d.ts).
        "noUncheckedSideEffectImports": false,
        "forceConsistentCasingInFileNames": true,
        "rootDir": ".",
        "paths": {
            "@core": ["./src/core"]
        },
        "module": "esnext",
        "target": "esnext",
        "moduleResolution": "bundler",
        "lib": ["DOM", "DOM.Iterable", "ESNext"],
        "types": ["vite/client"]
    }
}
